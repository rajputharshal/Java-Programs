<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE beans PUBLIC "-//SPRING//DTD BEAN 2.0//EN"
			"http://www.springframework.org/dtd/spring-beans-2.0.dtd">
			
<beans>
 <bean id="po"  class="springPackage.pojoclass">
 <property name="id" value="1"/>
 <property name="sal" value="108000000"/>
 <property name="name" value="ram"/>
  
 
 </bean>		
<bean id="c" class="springPackage.constructorPojo">
<constructor-arg value="harsh" type="java.lang.String" index="0"/>
<constructor-arg value="11" type="int" index="" />
</bean>

<bean id="cl" class="springPackage.collectionPojo">
<property name="name">
<list>
<value>harsh</value>
<value>sagar</value>
<value>maish</value>
</list>
</property>
</bean>

<bean id="m" class="springPackage.mappojo">
<property name="name">
<map>
<entry key="1" value="harsh"/>
<entry key="2" value="mangesh"/>
</map>
</property>
</bean>
</beans>