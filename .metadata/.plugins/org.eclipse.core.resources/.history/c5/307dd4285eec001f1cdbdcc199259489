package ArratPack;

public class Second_Max_Array {

	public static void main(String[] args) {
		int array[]= {33,22,77,12,9,23};
		int max=array[0];
		for(int i=0;i<array.length;i++)
		{
			for(int j=0;j<array.length;j++)
			{
				if(array[i]<array[j])
				{
					max=array[j];
					array[j]=array[i];
					array[i]=max;
				}
			}
		}
		for(int i=0;i<array.length;i++)
		{
			System.out.println(array[i]);
		}
	}

}
